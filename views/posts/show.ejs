<%- include('../partials/header') %>
<main class="container">
  <h1><%= post.title %></h1>
  <p><small>作者: <%= post.author?.name || '匿名' %> | 分类: <%= post.category?.name || '未分类' %> | <%= post.createdAt.toDateString() %></small></p>

  <!-- 编辑/删除按钮，仅作者可见 -->
  <div id="post-actions" style="margin-bottom:10px; display:none;">
    <a href="/posts/edit/<%= post.id %>" class="btn-edit">编辑</a>
    <button onclick="deletePost()" class="btn-delete">删除</button>
  </div>

  <!-- 作者卡片 -->
  <% if (post.author) { %>
  <div style="display: flex; align-items: center; background: #f9f6f0; padding: 12px 15px; border-radius: 8px; margin: 15px 0;">
    <img src="<%= post.author.avatar || '/default-avatar.png' %>" alt="<%= post.author.name %>" style="width:48px; height:48px; border-radius:50%; object-fit:cover; margin-right:15px;">
    <div>
      <strong><%= post.author.name || '匿名' %></strong>
      <% if (post.author.bio) { %>
        <p style="margin:3px 0 0; color:#666; font-size:0.9rem;"><%= post.author.bio %></p>
      <% } %>
    </div>
  </div>
  <% } %>

  <div class="post-content" style="text-align: left;">
    <%- post.content %>
  </div>
  <hr>

  <p>
    <button id="like-btn" data-post-id="<%= post.id %>">❤️ <span id="like-count">0</span></button>
  </p>

  <h3>评论</h3>
  <div id="comments-list">加载中...</div>
  <hr>
  <div id="comment-form" style="display:none;">
    <div id="reply-to" style="background:#f0ede5; padding:5px 10px; margin-bottom:5px; display:none;">
      回复 <span id="reply-name"></span>：<span id="reply-preview"></span> <a href="#" onclick="cancelReply()">取消</a>
    </div>
    <textarea id="comment-input" placeholder="写下你的评论..." rows="3" style="width:100%"></textarea>
    <button id="comment-submit">发表评论</button>
  </div>
  <p id="login-prompt">请先 <a href="/auth/login">登录</a> 后发表评论。</p>
</main>
<%- include('../partials/footer') %>

<style>
  .btn-edit { padding: 5px 10px; background: #4CAF50; color: white; text-decoration: none; border-radius: 3px; }
  .btn-delete { padding: 5px 10px; background: #f44336; color: white; border: none; border-radius: 3px; cursor: pointer; }
  .comment-item { border-bottom: 1px solid #eee; padding: 8px 0; }
  .reply-btn, .quote-btn { font-size: 0.85rem; margin-left: 10px; cursor: pointer; color: #8b7b6b; }
  .reply-form { margin-top: 5px; margin-left: 20px; }
  img { max-width: 100%; height: auto; }
</style>

<script>
(function() {
  var postId = <%= post.id %>;
  var token = localStorage.getItem('token');
  var replyParentId = null;

  // 作者显示编辑删除
  if (token) {
    fetch('/api/auth/me', { headers: {'Authorization':'Bearer '+token} })
      .then(r=>r.json())
      .then(user=>{ if(user.id===<%= post.authorId %>) document.getElementById('post-actions').style.display='block'; })
      .catch(()=>{});
  }

  window.deletePost = async function(){
    if(!confirm('确定删除？')) return;
    var res = await fetch('/posts/'+postId, {method:'DELETE', headers:{'Authorization':'Bearer '+token}});
    if(res.ok){ alert('已删除'); window.location.href='/posts'; }
    else { var e=await res.json(); alert(e.error||'删除失败'); }
  };

  // 点赞
  async function loadLikeCount(){
    var r = await fetch('/api/posts/'+postId+'/likes');
    var d = await r.json();
    document.getElementById('like-count').textContent = d.count;
  }
  document.getElementById('like-btn').addEventListener('click', async ()=>{
    if(!token){ alert('请先登录'); return; }
    await fetch('/api/posts/'+postId+'/like', {method:'POST', headers:{'Authorization':'Bearer '+token}});
    loadLikeCount();
  });

  // 评论渲染（递归显示嵌套回复）
  function renderCommentTree(comments) {
    if (!comments || comments.length === 0) return '';
    var html = '';
    comments.forEach(function(c) {
      html += '<div class="comment-item" id="comment-' + c.id + '">';
      html += '<div style="display:flex; align-items:center;">';
      html += '<img src="' + (c.user.avatar || '/default-avatar.png') + '" style="width:24px;height:24px;border-radius:50%; margin-right:8px;">';
      html += '<strong>' + (c.user.name || c.user.email) + '</strong>';
      html += '<span style="color:#999; font-size:0.8em; margin-left:10px;">' + new Date(c.createdAt).toLocaleString() + '</span>';
      html += '</div>';
      html += '<div style="margin:5px 0;">' + c.content.replace(/</g, '&lt;') + '</div>';
      html += '<div>';
      html += '<a class="reply-btn" onclick="replyTo(' + c.id + ', \'' + (c.user.name || c.user.email) + '\')">回复</a>';
      html += '<a class="quote-btn" onclick="quoteComment(' + c.id + ')">引用</a>';
      html += '</div>';
      // 递归显示子回复
      if (c.replies && c.replies.length > 0) {
        html += '<div style="margin-left:25px;">' + renderCommentTree(c.replies) + '</div>';
      }
      html += '</div>';
    });
    return html;
  }

  async function loadComments() {
    var res = await fetch('/api/posts/' + postId + '/comments');
    var comments = await res.json();
    var list = document.getElementById('comments-list');
    if (!comments || comments.length === 0) {
      list.innerHTML = '<p>暂无评论，来发表第一条吧！</p>';
      return;
    }
    list.innerHTML = renderCommentTree(comments);
  }

  // 回复功能
  window.replyTo = function(commentId, userName){
    replyParentId = commentId;
    document.getElementById('reply-to').style.display = 'block';
    document.getElementById('reply-name').textContent = userName;
    document.getElementById('reply-preview').textContent = '';
    document.getElementById('comment-input').focus();
  };

  window.cancelReply = function(){
    replyParentId = null;
    document.getElementById('reply-to').style.display = 'none';
  };

  // 引用评论
  window.quoteComment = function(commentId){
    fetch('/api/posts/'+postId+'/comments')
      .then(r=>r.json())
      .then(comments=>{
        var c = findCommentById(comments, commentId);
        if(!c) return;
        var quote = '> ' + c.content.replace(/\n/g, '\n> ') + '\n\n';
        var textarea = document.getElementById('comment-input');
        textarea.value = quote + textarea.value;
        textarea.focus();
      });
  };

  function findCommentById(comments, id) {
    for (var i = 0; i < comments.length; i++) {
      if (comments[i].id === id) return comments[i];
      if (comments[i].replies) {
        var found = findCommentById(comments[i].replies, id);
        if (found) return found;
      }
    }
    return null;
  }

  // 划线评论
  document.querySelector('.post-content').addEventListener('mouseup', function(e){
    var selection = window.getSelection();
    if(!selection.toString().trim()) return;
    var range = selection.getRangeAt(0);
    var rect = range.getBoundingClientRect();
    var toolbar = document.getElementById('selection-toolbar');
    if(!toolbar){
      toolbar = document.createElement('div');
      toolbar.id = 'selection-toolbar';
      toolbar.style.position = 'absolute';
      toolbar.style.background = '#333';
      toolbar.style.color = '#fff';
      toolbar.style.borderRadius = '4px';
      toolbar.style.padding = '4px 8px';
      toolbar.style.cursor = 'pointer';
      toolbar.style.zIndex = '9999';
      toolbar.textContent = '💬 评论';
      toolbar.addEventListener('click', function(){
        var text = selection.toString().trim();
        var quote = '> ' + text + '\n\n';
        var textarea = document.getElementById('comment-input');
        textarea.value = quote + textarea.value;
        textarea.focus();
        toolbar.remove();
      });
      document.body.appendChild(toolbar);
    }
    toolbar.style.left = (rect.left + window.scrollX) + 'px';
    toolbar.style.top = (rect.top + window.scrollY - 30) + 'px';
    toolbar.style.display = 'block';
    setTimeout(()=>{ if(toolbar) toolbar.style.display = 'none'; }, 3000);
  });

  // 提交评论
  document.getElementById('comment-submit').addEventListener('click', async ()=>{
    if(!token){ alert('请先登录'); return; }
    var content = document.getElementById('comment-input').value.trim();
    if(!content) return;
    var body = { content };
    if(replyParentId) body.parentId = replyParentId;
    var res = await fetch('/api/posts/'+postId+'/comments', {
      method: 'POST',
      headers: {'Content-Type':'application/json', 'Authorization':'Bearer '+token},
      body: JSON.stringify(body)
    });
    if(res.ok){
      document.getElementById('comment-input').value = '';
      cancelReply();
      loadComments();
    } else {
      var e = await res.json();
      alert(e.error || '评论失败');
    }
  });

  // 登录状态控制评论框
  if(token){
    document.getElementById('comment-form').style.display = 'block';
    document.getElementById('login-prompt').style.display = 'none';
  }

  loadLikeCount();
  loadComments();
})();
</script>