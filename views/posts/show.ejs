<%- include('../partials/header') %>
<div class="container">
  <h1><%= post.title %></h1>
  <p class="meta" style="color: var(--text-secondary);">
    ✍️ <%= post.author?.name || '匿名' %> · 🗂️ <%= post.category?.name || '未分类' %> · 📅 <%= post.createdAt.toDateString() %>
  </p>

  <div id="post-actions" style="margin: 16px 0; display:none;">
    <a href="/posts/edit/<%= post.id %>" class="btn btn-edit">编辑</a>
    <button onclick="deletePost()" class="btn btn-delete" style="margin-left:8px;">删除</button>
  </div>

  <div class="card post-content">
    <%- post.content %>
  </div>

  <div style="margin-top: 24px;">
    <button id="like-btn" class="like-btn" data-post-id="<%= post.id %>">
      ❤️ <span id="like-count">0</span>
    </button>
  </div>

  <h3 style="margin-top: 32px;">💬 评论</h3>
  <div id="comments-list" style="margin: 16px 0;"></div>

  <div id="comment-form" style="display:none;">
    <textarea id="comment-input" placeholder="写下你的评论..." rows="3"></textarea>
    <button id="comment-submit" class="btn btn-primary">发表评论</button>
  </div>
  <p id="login-prompt" style="margin-top: 16px;">请先 <a href="/auth/login">登录</a> 后发表评论。</p>
</div>

<script>
  (function() {
    var postId = <%= post.id %>;
    var token = localStorage.getItem('token');

    if (token) {
      fetch('/api/auth/me', { headers: { 'Authorization': 'Bearer ' + token } })
        .then(r => r.json())
        .then(user => {
          if (user.id === <%= post.authorId %>) {
            document.getElementById('post-actions').style.display = 'block';
          }
        });
    }

    window.deletePost = async function() {
      if (!confirm('确定要删除这篇文章吗？')) return;
      var res = await fetch('/posts/' + postId, {
        method: 'DELETE',
        headers: { 'Authorization': 'Bearer ' + token }
      });
      if (res.ok) {
        alert('删除成功');
        window.location.href = '/posts';
      }
    };

    async function loadLikeCount() {
      var res = await fetch('/api/posts/' + postId + '/likes');
      var data = await res.json();
      document.getElementById('like-count').textContent = data.count;
    }
    document.getElementById('like-btn').addEventListener('click', async () => {
      if (!token) { alert('请先登录'); return; }
      await fetch('/api/posts/' + postId + '/like', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token }
      });
      loadLikeCount();
    });

    async function loadComments() {
      var res = await fetch('/api/posts/' + postId + '/comments');
      var comments = await res.json();
      var list = document.getElementById('comments-list');
      if (comments.length === 0) {
        list.innerHTML = '<p style="color: var(--text-secondary);">暂无评论</p>';
        return;
      }
      list.innerHTML = comments.map(c =>
        '<div class="comment-item">' +
        '<strong>' + (c.user.name || c.user.email) + '</strong>' +
        '<span style="float:right; font-size:0.85rem; color: var(--text-secondary);">' + new Date(c.createdAt).toLocaleString() + '</span>' +
        '<p style="margin-top:6px;">' + c.content.replace(/</g, '&lt;') + '</p>' +
        '</div>'
      ).join('');
    }

    if (token) {
      document.getElementById('comment-form').style.display = 'block';
      document.getElementById('login-prompt').style.display = 'none';
    }

    document.getElementById('comment-submit').addEventListener('click', async () => {
      var content = document.getElementById('comment-input').value.trim();
      if (!content) return;
      var res = await fetch('/api/posts/' + postId + '/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ content })
      });
      if (res.ok) {
        document.getElementById('comment-input').value = '';
        loadComments();
      }
    });

    loadLikeCount();
    loadComments();
  })();
</script>