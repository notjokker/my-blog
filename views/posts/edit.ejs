<%- include('../partials/header') %>
<h1><%= post ? '编辑文章' : '写新文章' %></h1>
<form id="post-form">
  <input type="text" id="title" placeholder="标题" required style="width:100%;" value="<%= post ? post.title : '' %>"><br><br>
  
  <!-- 分类选择 -->
  <label>分类：</label>
  <select id="categoryId">
    <option value="">无分类</option>
    <% if (typeof categories !== 'undefined') { categories.forEach(cat => { %>
      <option value="<%= cat.id %>" <%= (post && post.categoryId === cat.id) ? 'selected' : '' %>><%= cat.name %></option>
    <% })} %>
  </select><br><br>

  <textarea id="content" placeholder="支持 Markdown 语法..." rows="15" style="width:100%;"><%= post ? post.content : '' %></textarea><br><br>
  <button type="submit">保存</button>
  <a href="/posts">取消</a>
</form>

<script>
(function() {
  var postId = <%= post ? post.id : 'null' %>;
  var token = localStorage.getItem('token');
  if (!token) { alert('请先登录'); window.location.href = '/auth/login'; return; }

  document.getElementById('post-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var title = document.getElementById('title').value;
    var content = document.getElementById('content').value;
    var url = postId ? '/posts/' + postId : '/posts';
    var method = postId ? 'PUT' : 'POST';
    try {
      var res = await fetch(url, {
        method: method,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + token
        },
        body: JSON.stringify({ title: title, content: content })
      });
      if (res.ok) {
        window.location.href = '/posts';
      } else {
        var err = await res.json();
        alert(err.error || '保存失败');
      }
    } catch (err) {
      alert('网络错误');
    }
  });
})();
</script>