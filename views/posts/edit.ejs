<%- include('../partials/header') %>
<main class="container">
  <h1><%= post ? '编辑文章' : '写新文章' %></h1>
  <form id="post-form">
    <input type="text" id="title" placeholder="标题" required style="width:100%;" value="<%= post ? post.title : '' %>"><br><br>
    
    <!-- 分类选择 -->
    <label>分类：</label>
    <select id="categoryId">
      <option value="">无分类</option>
      <% if (typeof categories !== 'undefined') { categories.forEach(cat => { %>
        <option value="<%= cat.id %>" <%= (post && post.categoryId === cat.id) ? 'selected' : '' %>><%= cat.name %></option>
      <% })} %>
    </select><br><br>

    <!-- 图片上传 -->
    <div>
      <label>图片：</label>
      <input type="file" id="image-file" accept="image/*">
      <button type="button" id="upload-btn">上传图片</button>
      <span id="upload-status"></span>
      <br>
      <small>点击“上传图片”后，图片链接会自动插入到文章末尾</small>
    </div>
    <br>
    
    <textarea id="content" placeholder="支持 Markdown 语法..." rows="15" style="width:100%;"><%= post ? post.content : '' %></textarea><br><br>
    <button type="submit">保存</button>
    <a href="/posts">取消</a>
  </form>
</main>
<%- include('../partials/footer') %>

<script>
(function() {
  var postId = <%= post ? post.id : 'null' %>;
  var token = localStorage.getItem('token');
  if (!token) { alert('请先登录'); window.location.href = '/auth/login'; return; }

   document.getElementById('upload-btn').addEventListener('click', async function() {
    var fileInput = document.getElementById('image-file');
    var file = fileInput.files[0];
    if (!file) {
      alert('请先选择一张图片');
      return;
    }
    var formData = new FormData();
    formData.append('image', file);
    var statusEl = document.getElementById('upload-status');
    statusEl.textContent = '上传中...';
    try {
      var res = await fetch('/api/upload', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token },
        body: formData
      });
      if (res.ok) {
        var data = await res.json();
        // 将 Markdown 图片语法插入到文章内容末尾
        var contentArea = document.getElementById('content');
        contentArea.value += '\n![](' + data.url + ')';
        statusEl.innerHTML = '<span style="color:green;">上传成功</span>';
      } else {
        var err = await res.json();
        statusEl.innerHTML = '<span style="color:red;">' + (err.error || '上传失败') + '</span>';
      }
    } catch (e) {
      statusEl.innerHTML = '<span style="color:red;">网络错误</span>';
    }
  });

  document.getElementById('post-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var title = document.getElementById('title').value;
    var content = document.getElementById('content').value;
    var url = postId ? '/posts/' + postId : '/posts';
    var method = postId ? 'PUT' : 'POST';
    try {
      var res = await fetch(url, {
        method: method,
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + token
        },
        body: JSON.stringify({ title: title, content: content })
      });
      if (res.ok) {
        window.location.href = '/posts';
      } else {
        var err = await res.json();
        alert(err.error || '保存失败');
      }
    } catch (err) {
      alert('网络错误');
    }
  });
})();
</script>