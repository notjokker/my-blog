<%- include('../partials/header') %>
<div class="container">
  <h1 style="margin-bottom:20px;">📝 博客文章</h1>
  <!-- 分类筛选 -->
  <p>
    <a href="/posts">全部</a>
    <% categories.forEach(cat => { %>
      | <a href="/posts?category=<%= cat.id %>"><%= cat.name %></a>
    <% }) %>
  </p>
  <% if (posts.length === 0) { %>
    <p>暂无文章，成为第一个作者吧！</p>
  <% } else { %>
    <% posts.forEach(post => { %>
      <div class="post">
        <h2><a href="/posts/<%= post.id %>"><%= post.title %></a></h2>
        <p><small>✍️ <%= post.author?.name || '匿名' %> · 🗂️ <%= post.category?.name || '未分类' %> · 📅 <%= post.createdAt.toDateString() %></small></p>
        <p><span class="like-count" data-post-id="<%= post.id %>">❤️ <span id="count-<%= post.id %>">0</span></span></p>
      </div>
    <% }) %>
  <% } %>
</div>
<script>
  // 加载点赞数（保持不变）
  document.querySelectorAll('.like-count').forEach(el => {
    const postId = el.dataset.postId;
    fetch(`/api/posts/${postId}/likes`)
      .then(res => res.json())
      .then(data => {
        document.getElementById('count-' + postId).textContent = data.count;
      });
  });
</script>