<%- include('../partials/header') %>
<main class="container">
  <h1 style="margin-bottom: 24px;">博客文章</h1>
  <p style="margin-bottom: 24px;">
    <a href="/posts">全部</a>
    <% categories.forEach(cat => { %>
      | <a href="/posts?category=<%= cat.id %>" class="category-link"><%= cat.name %></a>
    <% }) %>
  </p>

  <% if (posts.length === 0) { %>
    <p>暂无文章。</p>
  <% } else { %>
    <% posts.forEach(post => { %>
      <div class="post-card">
        <h2><a href="/posts/<%= post.id %>"><%= post.title %></a></h2>
        <div class="meta">
          ✍️ <%= post.author?.name || '匿名' %> · 🗂️ <%= post.category?.name || '未分类' %> · 📅 <%= post.createdAt.toDateString() %>
        </div>
        <p>
          <span class="like-btn" data-post-id="<%= post.id %>">
            ❤️ <span id="count-<%= post.id %>">0</span>
          </span>
        </p>
      </div>
    <% }) %>
  <% } %>
</main>
<%- include('../partials/footer') %>

<script>
  document.querySelectorAll('.like-btn').forEach(el => {
    const postId = el.dataset.postId;
    fetch(`/api/posts/${postId}/likes`)
      .then(res => res.json())
      .then(data => {
        document.getElementById('count-' + postId).textContent = data.count;
      });
  });
</script>