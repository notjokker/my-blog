<%- include('partials/header', { title: '首页' }) %>

<h1>最新文章</h1>
<% if (posts.length === 0) { %>
  <p>还没有文章，快去写第一篇吧！</p>
<% } else { %>
  <div class="post-list">
    <% posts.forEach(post => { %>
      <article class="post-card">
        <h2><a href="/post/<%= post.slug %>"><%= post.title %></a></h2>
        <div class="meta">
          <time><%= post.date %></time>
          <% if (post.tags.length) { %>
            <span class="tags">
              <% post.tags.forEach(tag => { %>
                <span class="tag"><%= tag %></span>
              <% }) %>
            </span>
          <% } %>
        </div>
        <% if (post.excerpt) { %>
          <p class="excerpt"><%= post.excerpt %></p>
        <% } %>
      </article>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
